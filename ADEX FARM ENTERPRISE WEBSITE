    <style>
        /* --- GLOBAL & TOKENS --- */
        :root {
            --primary: #1B4332;
            --primary-light: #2d6a4f;
            --cta-gold: #D4A373;
            --cta-gold-hover: #bfa054;
            --earth-brown: #5C4033;
            --cream-bg: #FEFAE0;
            --accent-red: #C1121F;
            --whatsapp-green: #25D366;
            --text-dark: #222222;
            --text-light: #FFFFFF;
            --font-heading: 'Playfair Display', Georgia, serif;
            --font-body: 'Inter', sans-serif;
            --transition: all 0.3s ease-in-out;
            --container-max: 1200px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-body);
            background-color: var(--text-light);
            color: var(--text-dark);
            line-height: 1.6;
            overflow-x: hidden;
        }

        h1, h2, h3, h4 {
            font-family: var(--font-heading);
            font-weight: 700;
        }

        img {
            max-width: 100%;
            height: auto;
            display: block;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        .container {
            width: 100%;
            max-width: var(--container-max);
            margin: 0 auto;
            padding: 0 24px;
        }

        /* --- BUTTONS --- */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            font-weight: 600;
            padding: 14px 28px;
            border-radius: 50px;
            border: none;
            cursor: pointer;
            transition: var(--transition);
            font-family: var(--font-body);
            font-size: 16px;
        }

        .btn-whatsapp {
            background-color: var(--whatsapp-green);
            color: var(--text-light);
            box-shadow: 0 4px 14px rgba(37, 211, 102, 0.2);
        }

        .btn-whatsapp:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(37, 211, 102, 0.3);
        }

        .btn-gold {
            background-color: var(--cta-gold);
            color: var(--text-light);
        }

        .btn-gold:hover {
            background-color: var(--cta-gold-hover);
            transform: translateY(-2px);
        }

        .btn-outline {
            border: 2px solid var(--cream-bg);
            color: var(--cream-bg);
            background: transparent;
        }

        .btn-outline:hover {
            background-color: var(--cream-bg);
            color: var(--primary);
        }

        .btn-brown {
            background-color: var(--earth-brown);
            color: var(--text-light);
        }

        .btn-brown:hover {
            opacity: 0.9;
        }

        /* --- GLOBAL STICKY NAV --- */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 80px;
            z-index: 1000;
            transition: var(--transition);
            display: flex;
            align-items: center;
            background: transparent;
        }

        .navbar.scrolled {
            background: var(--primary);
            height: 70px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        }

        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            width: 100%;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 10px;
            font-family: var(--font-heading);
            font-size: 24px;
            color: var(--text-light);
            font-weight: bold;
        }

        .logo-circle {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            border: 2px dashed var(--cta-gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            background: var(--text-light);
            color: var(--primary);
            font-weight: 800;
        }

        .nav-links {
            display: flex;
            gap: 24px;
            list-style: none;
        }

        .nav-links a {
            color: var(--cream-bg);
            font-size: 15px;
            font-weight: 500;
            transition: var(--transition);
        }

        .nav-links a:hover {
            color: var(--cta-gold);
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            border: none;
            background: transparent;
        }

        .hamburger span {
            width: 25px;
            height: 3px;
            background-color: var(--text-light);
            transition: var(--transition);
        }

        /* --- SECTION 1: HERO --- */
        .hero {
            height: 100vh;
            min-height: 650px;
            background: linear-gradient(135deg, rgba(27,67,50,0.9) 0%, rgba(27,67,50,0.55) 100%), 
                        url('https://images.unsplash.com/photo-1588166524941-3bf61a9c41db?q=80&w=1600&auto=format&fit=crop') center/cover no-repeat; /* [REPLACE with Screenshot_20260522-225105_Instagram.jpg raw asset] */
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            position: relative;
            padding-top: 80px;
        }

        .hero-content {
            max-width: 850px;
            animation: fadeInUp 1s ease-out;
        }

        .hero-eyebrow {
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 3px;
            color: var(--cta-gold);
            margin-bottom: 20px;
            text-transform: uppercase;
        }

        .hero h1 {
            font-size: clamp(36px, 5vw, 56px);
            color: var(--text-light);
            line-height: 1.2;
            margin-bottom: 24px;
        }

        .hero-sub {
            font-size: 18px;
            color: var(--cream-bg);
            margin-bottom: 40px;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }

        .hero-ctas {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin-bottom: 48px;
        }

        .trust-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            justify-content: center;
            list-style: none;
        }

        .trust-pill {
            background: rgba(254, 250, 224, 0.15);
            color: var(--cream-bg);
            padding: 8px 16px;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 500;
            backdrop-filter: blur(5px);
        }

        .scroll-indicator {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            color: var(--cta-gold);
            font-size: 24px;
            animation: bounce 2s infinite;
        }

        /* --- SECTION 2: HOW IT WORKS --- */
        .process-section {
            background-color: var(--cream-bg);
            padding: 60px 0;
            text-align: center;
        }

        .process-section h2 {
            font-size: 32px;
            color: var(--earth-brown);
            margin-bottom: 40px;
        }

        .process-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 30px;
            position: relative;
            margin-bottom: 40px;
        }

        .process-card {
            background: var(--text-light);
            padding: 30px 20px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            position: relative;
            transition: var(--transition);
        }

        .process-card:hover {
            transform: translateY(-5px);
        }

        .process-icon {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background-color: rgba(27,67,50,0.1);
            color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin: 0 auto 20px;
        }

        .process-card h3 {
            font-size: 18px;
            margin-bottom: 10px;
            color: var(--primary);
        }

        .process-card p {
            font-size: 14px;
            color: #666;
        }

        /* --- SECTION 3: SERVICES GRID --- */
        .services-section {
            padding: 80px 0;
            background: var(--text-light);
        }

        .section-header {
            text-align: center;
            max-width: 600px;
            margin: 0 auto 60px;
        }

        .section-eyebrow {
            font-size: 13px;
            letter-spacing: 2px;
            color: var(--primary);
            font-weight: 600;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .section-header h2 {
            font-size: 36px;
            color: var(--earth-brown);
            margin-bottom: 15px;
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .service-card {
            background: var(--text-light);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            transition: var(--transition);
            border-top: 4px solid transparent;
            display: flex;
            flex-direction: column;
        }

        .service-card:nth-child(1) { border-top-color: var(--cta-gold); }
        .service-card:nth-child(2) { border-top-color: var(--accent-red); }
        .service-card:nth-child(3) { border-top-color: var(--primary); }

        .service-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.1);
        }

        .service-img {
            height: 220px;
            overflow: hidden;
            position: relative;
        }

        .service-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .service-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            color: white;
        }

        .badge-green { background-color: var(--primary); }
        .badge-gold { background-color: var(--cta-gold); }

        .service-body {
            padding: 30px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .service-icon-inline {
            font-size: 24px;
            margin-bottom: 15px;
        }
        .c1 { color: var(--earth-brown); }
        .c2 { color: var(--accent-red); }
        .c3 { color: var(--primary); }

        .service-body h3 {
            font-size: 22px;
            margin-bottom: 12px;
            color: var(--primary);
        }

        .service-body p {
            font-size: 15px;
            color: #555;
            margin-bottom: 20px;
            flex-grow: 1;
        }

        .price-indicator {
            font-size: 20px;
            font-weight: 700;
            color: var(--cta-gold);
            margin-bottom: 20px;
        }

        .service-cta {
            font-weight: 600;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition);
        }

        .service-card:hover .service-cta {
            gap: 14px;
            color: var(--cta-gold);
        }

        /* --- SECTION 4: WHY ADEX FARM (SPLIT) --- */
        .split-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            min-height: 600px;
        }

        .split-left {
            background: linear-gradient(rgba(27,67,50,0.4), rgba(27,67,50,0.7)), 
                        url('https://images.unsplash.com/photo-1546445317-29f4545e9d53?q=80&w=800&auto=format&fit=crop') center/cover no-repeat; /* [REPLACE with cattle garden / livestock photo] */
            position: relative;
            padding: 40px;
            display: flex;
            align-items: flex-end;
        }

        .split-caption {
            background: rgba(255,255,255,0.95);
            padding: 15px 25px;
            border-radius: 8px;
            font-weight: 600;
            color: var(--primary);
            font-size: 14px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .split-right {
            background-color: var(--cream-bg);
            padding: 80px 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .split-right h2 {
            font-size: 36px;
            color: var(--primary);
            margin-bottom: 40px;
        }

        .benefit-list {
            display: flex;
            flex-direction: column;
            gap: 24px;
            margin-bottom: 40px;
        }

        .benefit-item {
            display: flex;
            gap: 20px;
        }

        .benefit-icon {
            font-size: 22px;
            color: var(--cta-gold);
            margin-top: 4px;
        }

        .benefit-text h4 {
            font-family: var(--font-body);
            font-size: 18px;
            color: var(--earth-brown);
            margin-bottom: 4px;
        }

        .benefit-text p {
            font-size: 14px;
            color: #555;
        }

        .split-ctas {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .link-review {
            font-weight: 600;
            color: var(--primary);
            border-bottom: 2px solid var(--primary);
            padding-bottom: 2px;
        }

        /* --- SECTION 5: MAMA ADEX MARKETPLACE --- */
        .marketplace-section {
            background: linear-gradient(180deg, var(--earth-brown) 0%, var(--primary) 100%);
            padding: 80px 0;
            color: var(--text-light);
        }

        .market-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 50px;
            align-items: center;
        }

        .market-content .section-eyebrow {
            color: var(--cta-gold);
        }

        .market-content h2 {
            font-size: 42px;
            color: var(--cta-gold);
            margin-bottom: 20px;
        }

        .market-sub {
            font-size: 17px;
            color: var(--cream-bg);
            margin-bottom: 30px;
        }

        .market-list {
            list-style: none;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 40px;
        }

        .market-list li {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 15px;
            color: var(--cream-bg);
        }

        .market-list li i {
            color: var(--cta-gold);
        }

        .masonry-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .masonry-img {
            border-radius: 12px;
            overflow: hidden;
            border: 2px solid rgba(254,250,224,0.2);
            height: 180px;
        }

        .masonry-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .market-strip {
            margin-top: 60px;
            border-top: 1px solid rgba(254,250,224,0.2);
            padding-top: 30px;
            text-align: center;
        }

        .market-strip em {
            font-size: 22px;
            color: var(--cream-bg);
            display: block;
            margin-bottom: 10px;
        }

        .market-strip p {
            font-size: 18px;
            font-weight: 600;
            color: var(--cta-gold);
        }

        /* --- SECTION 6: PRICING & PACKAGES --- */
        .pricing-section {
            padding: 80px 0;
            background: var(--text-light);
        }

        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            align-items: flex-start;
        }

        .pricing-card {
            background: var(--text-light);
            border-radius: 16px;
            padding: 40px 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.03);
            border-top: 4px solid transparent;
            position: relative;
            display: flex;
            flex-direction: column;
        }

        .p-card-1 { border-top-color: var(--cta-gold); }
        .p-card-2 { 
            border-top-color: var(--primary); 
            box-shadow: 0 15px 40px rgba(27,67,50,0.12);
            transform: scale(1.03);
        }
        .p-card-3 { border-top-color: var(--earth-brown); }

        .pop-badge {
            position: absolute;
            top: -15px;
            right: 20px;
            background-color: var(--primary);
            color: white;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }

        .pricing-card h3 {
            font-size: 24px;
            color: var(--primary);
            margin-bottom: 4px;
        }

        .pricing-card .p-sub {
            font-size: 14px;
            color: #777;
            margin-bottom: 24px;
        }

        .pricing-card .price {
            font-size: 32px;
            font-weight: 800;
            color: var(--text-dark);
            margin-bottom: 30px;
        }

        .price-features {
            list-style: none;
            margin-bottom: 35px;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .price-features li {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 15px;
            color: #444;
        }

        .price-features i {
            color: var(--primary);
            font-size: 14px;
        }

        .pricing-card .btn {
            width: 100%;
        }

        .pricing-note {
            text-align: center;
            margin-top: 40px;
            font-size: 14px;
            color: #666;
        }

        /* --- SECTION 7: TESTIMONIALS --- */
        .testimonials-section {
            background-color: var(--primary);
            padding: 80px 0;
            color: var(--text-light);
            text-align: center;
        }

        .testimonials-section h2 {
            color: var(--cta-gold);
            font-size: 36px;
            margin-bottom: 50px;
        }

        .carousel-container {
            max-width: 1000px;
            margin: 0 auto 50px;
            position: relative;
            overflow: hidden;
        }

        .carousel-track {
            display: flex;
            transition: transform 0.5s ease-in-out;
            gap: 30px;
        }

        .testimonial-slide {
            min-width: calc(33.333% - 20px);
            background: rgba(255,255,255,0.05);
            padding: 40px 30px;
            border-radius: 12px;
            text-align: left;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .test-stars {
            color: var(--cta-gold);
            margin-bottom: 15px;
            font-size: 14px;
        }

        .testimonial-slide p {
            font-size: 15px;
            color: var(--cream-bg);
            font-style: italic;
            margin-bottom: 24px;
        }

        .test-meta h5 {
            font-size: 16px;
            color: var(--text-light);
        }

        .test-meta span {
            font-size: 13px;
            color: var(--cta-gold);
            display: block;
        }

        .test-tag {
            display: inline-block;
            margin-top: 10px;
            background: rgba(212,163,115,0.2);
            color: var(--cta-gold);
            padding: 3px 10px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 600;
        }

        .carousel-dots {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-bottom: 40px;
        }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: rgba(254,250,224,0.3);
            cursor: pointer;
        }

        .dot.active {
            background: var(--cta-gold);
        }

        .ig-preview h4 {
            font-size: 18px;
            margin-bottom: 20px;
            color: var(--cream-bg);
        }

        .ig-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 15px;
        }

        .ig-item {
            aspect-ratio: 1;
            border-radius: 8px;
            overflow: hidden;
            background: #eee;
        }

        .ig-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* --- SECTION 8: DELIVERY & LOCATION --- */
        .delivery-section {
            background-color: var(--cream-bg);
            padding: 80px 0;
        }

        .delivery-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
        }

        .delivery-left h3 {
            font-size: 32px;
            color: var(--primary);
            margin-bottom: 24px;
        }

        .zone-list {
            list-style: none;
            margin-bottom: 24px;
        }

        .zone-list li {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid rgba(0,0,0,0.06);
            font-size: 15px;
        }

        .zone-list strong { color: var(--earth-brown); }

        .fee-note {
            background: rgba(27,67,50,0.05);
            padding: 15px;
            border-left: 4px solid var(--primary);
            border-radius: 4px;
            font-size: 14px;
            margin-bottom: 30px;
        }

        .zone-checker {
            display: flex;
            gap: 10px;
        }

        .zone-checker input {
            flex-grow: 1;
            padding: 14px 20px;
            border-radius: 35px;
            border: 1px solid #ccc;
